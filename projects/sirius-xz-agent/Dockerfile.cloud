FROM maven:3.9.9-eclipse-temurin-21 AS build

WORKDIR /workspace
COPY pom.xml .
COPY src ./src
RUN mvn -q -DskipTests package

FROM eclipse-temurin:21-jre

WORKDIR /app
COPY --from=build /workspace/target/sirius-xz-agent-0.1.0-SNAPSHOT.jar /app/app.jar

EXPOSE 26000
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
